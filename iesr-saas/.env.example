# Neon Postgres — use the POOLED connection string for serverless (…-pooler.…)
DATABASE_URL="postgres://USER:PASSWORD@ep-xxxx-pooler.REGION.aws.neon.tech/iesr?sslmode=require"

# 32+ byte secret for signing session JWTs:  openssl rand -base64 48
AUTH_SECRET="replace-me-with-a-long-random-secret"

# Single-school deployment: the school this instance serves.
# Created by `npm run db:seed`; copy the printed id here.
DEFAULT_SCHOOL_ID=""

# Session lifetime (seconds). Default 8h.
SESSION_MAX_AGE="28800"
